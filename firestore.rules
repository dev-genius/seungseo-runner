rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Leaderboard for the seungseo-runner game.
    // Anyone can read the top scores; new entries can only be created
    // (never edited or deleted) and must match a small, validated shape.
    match /leaderboards/seungseo-runner/entries/{entryId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name','score','ts'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 60
                    && request.resource.data.score is number
                    && request.resource.data.score > 0
                    && request.resource.data.score <= 200000
                    && request.resource.data.ts == request.time;
      allow update, delete: if false;
    }

    // Pre-existing project default (test-mode) rule, left as-is so other
    // data in this project isn't affected by this change. It already
    // expires on 2026-08-04; after that, only the explicit rules above
    // (and any added later) will apply.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 8, 4);
    }
  }
}
